---
import CardImagenAlondra from "../ui/CardImagenAlondra.astro";
import CardTexto from "../ui/cardTexto.astro";
---

<section
  class:list={["bg-gradient-to-r", "from-crema1", "via-crema2", "to-crema3"]}
>
  <h2
    class:list={[
      "text-center",
      "text-5xl",
      "font-bold",
      "text-brown/80",
      "sm:py-8",
      "py-12"
    ]}
  >
    ¿Quien Soy?
  </h2>
  <article
    class:list={[
      "flex",
      "sm:flex-row",
      "flex-col",
      "items-center",
      "justify-center",
      "sm:gap-10",
      "sm:mt-4",
    ]}
  >
    <div class:list={[]}>
      <CardTexto
        nombre="Alondra Aldana"
        descripcion="Soy una nutrióloga apasionada y comprometida a transformar vidas a través de una alimentación consciente y realista, con dedicación y un enfoque integral. Mi objetivo es ayudar a mis pacientes a alcanzar un equilibrio entre la salud, bienestar y placer por la comida. ¡Me encantaría ser parte de tu cambio!"
        badges={[
          { text: "Nutrición Clínica", color: "crema" },
          { text: "Nutrición Deportiva", color: "crema" },
          { text: "Nutrición Preventiva", color: "crema" },
          { text: "Nutrición Geriatrica", color: "crema" },
        ]}
      />
    </div>
    <div class:list={["sm:-ml-14", "sm:mt-20", "mt-5"]}>
      <CardImagenAlondra
        src="/images/AlondraAldana.jpeg"
        alt="Alondra Aldana"
      />
    </div>
  </article>
</section>
