---
const precios = [
  {
    titulo: "Plan Básico",
    etiqueta: "Ideal para iniciar",
    descripcion: "Consulta inicial, evaluación personalizada y plan de alimentación adaptado a tus objetivos.",
    precio: "$350",
    periodo: "MXN/mes",
    botonTexto: "Quiero este plan",
    destacado: false,
    beneficios: [
      "Consulta inicial personalizada",
      "Plan de alimentación mensual",
      "Recomendaciones prácticas",
    ],
  },
  {
    titulo: "Plan Duo",
    etiqueta: "Para dos personas",
    descripcion: "Acompañamiento nutricional para dos personas con planes personalizados según sus necesidades.",
    precio: "$500",
    periodo: "MXN/mes",
    botonTexto: "Agendar plan duo",
    destacado: true,
    beneficios: [
      "Consulta inicial para dos personas",
      "Planes personalizados",
      "Seguimiento de avances",
    ],
  },
  {
    titulo: "Plan Premium",
    etiqueta: "Más completo",
    descripcion: "Plan integral con seguimiento semanal para mantener constancia y lograr mejores resultados.",
    precio: "$500",
    periodo: "MXN/mes",
    botonTexto: "Elegir premium",
    destacado: false,
    beneficios: [
      "Consulta inicial completa",
      "Seguimiento semanal",
      "Ajustes personalizados",
    ],
  },
];
---

<section class="relative overflow-hidden bg-gradient-to-b from-crema3 via-crema2 to-crema3 py-24 px-4">
  <div class="pointer-events-none absolute -top-32 -left-24 h-20 w-80 rounded-full bg-[#9A9A22]/10 blur-3xl"></div>
  <div class="pointer-events-none absolute bottom-0 right-0 h-96 w-96 rounded-full bg-[#8B6F47]/10 blur-3xl"></div>

  <div class="container relative z-10 mx-auto">
    <div class="mx-auto max-w-3xl text-center">
      <span class="inline-flex rounded-full border border-brown/15 bg-white/25 px-5 py-2 text-sm font-semibold uppercase tracking-[0.25em] text-brown/60 backdrop-blur-md">
        Planes personalizados
      </span>

      <h2 class="mt-6 font-serif text-4xl font-bold uppercase tracking-wide text-brown/85 sm:text-5xl md:text-6xl">
        Precios de plan mensual
      </h2>

      <p class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-brown/65 md:text-lg">
        Elige el acompañamiento nutricional que mejor se adapte a tus objetivos.
        Planes diseñados para crear hábitos reales, sostenibles y sin restricciones extremas.
      </p>
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-3">
      {
        precios.map((plan) => (
          <article
            class:list={[
              "group relative overflow-hidden rounded-[2rem] border p-8 text-center transition-all duration-500",
              "bg-white/25 backdrop-blur-xl",
              "shadow-[0_24px_70px_rgba(94,73,53,0.12)]",
              "hover:-translate-y-3 hover:shadow-[0_30px_90px_rgba(94,73,53,0.22)]",
              plan.destacado
                ? "border-[#9A9A22]/45 scale-[1.02] bg-[#E7D69B]/45"
                : "border-white/35",
            ]}
          >
            {plan.destacado && (
              <div class="absolute right-6 top-6 rounded-full bg-[#9A9A22] px-4 py-1.5 text-xs font-bold uppercase tracking-wider text-white shadow-lg">
                Popular
              </div>
            )}

            <div class="pointer-events-none absolute -top-20 left-1/2 h-44 w-44 -translate-x-1/2 rounded-full bg-white/25 blur-3xl transition duration-500 group-hover:bg-white/40"></div>

            <div class="relative z-10">
              <div
                class:list={[
                  "mx-auto flex h-16 w-16 items-center justify-center rounded-2xl border shadow-lg",
                  plan.destacado
                    ? "border-[#9A9A22]/25 bg-[#9A9A22]/90 text-white"
                    : "border-white/50 bg-white/35 text-brown/70",
                ]}
              >
                <svg class="h-8 w-8" viewBox="0 0 24 24" fill="none">
                  <path
                    d="M8 6h11M8 12h11M8 18h11M4 6h.01M4 12h.01M4 18h.01"
                    stroke="currentColor"
                    stroke-width="2.4"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </div>

              <span class="mt-6 inline-block text-sm font-semibold uppercase tracking-[0.22em] text-brown/45">
                {plan.etiqueta}
              </span>

              <h3 class="mt-3 font-serif text-3xl font-bold text-brown/85">
                {plan.titulo}
              </h3>

              <p class="mx-auto mt-4 min-h-[84px] max-w-xs text-sm leading-relaxed text-brown/60">
                {plan.descripcion}
              </p>

              <div class="mt-6 flex items-end justify-center gap-1">
                <span class="font-serif text-5xl font-bold text-brown/90">
                  {plan.precio}
                </span>
                <span class="mb-2 text-sm font-semibold text-brown/55">
                  {plan.periodo}
                </span>
              </div>

              <ul class="mt-7 space-y-3 text-left">
                {plan.beneficios.map((beneficio) => (
                  <li class="flex items-center gap-3 text-sm text-brown/65">
                    <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-[#9A9A22]/15 text-[#8A8A1E]">
                      ✓
                    </span>
                    <span>{beneficio}</span>
                  </li>
                ))}
              </ul>

              <a
                href="#contacto"
                class:list={[
                  "mt-8 inline-flex w-full items-center justify-center rounded-full px-6 py-3 text-sm font-bold transition-all duration-300",
                  plan.destacado
                    ? "bg-[#9A9A22] text-white shadow-[0_14px_30px_rgba(154,154,34,0.28)] hover:bg-[#85851D]"
                    : "border border-brown/20 bg-white/30 text-brown/75 hover:bg-brown/80 hover:text-white",
                ]}
              >
                {plan.botonTexto}
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>