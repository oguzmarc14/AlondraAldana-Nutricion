---
interface Props {
  titulo: string;
  descripcion: string;
}

const { titulo, descripcion } = Astro.props;
---

<article
  class:list={[
    "group",
    "relative",
    "overflow-hidden",

    "max-w-[340px]",
    "rounded-[28px]",

    "border",
    "border-white/35",

    "bg-white/30",
    "backdrop-blur-xl",

    "p-8",

    "shadow-[0_20px_50px_rgba(94,73,53,0.12)]",

    "transition-all",
    "duration-500",

    "hover:-translate-y-2",
    "hover:shadow-[0_30px_70px_rgba(94,73,53,0.20)]",
  ]}
>
  <!-- Glow decorativo -->
  <div
    class="absolute -top-10 -right-10 h-32 w-32 rounded-full bg-[#D8D49A]/25 blur-3xl transition-all duration-500 group-hover:scale-125"
  ></div>

  <div class="relative z-10">
    <h3
      class:list={[
        "font-serif",
        "text-2xl",
        "font-bold",
        "text-brown/85",
        "mb-4",
        "leading-tight",
      ]}
    >
      {titulo}
    </h3>

    <div
      class="mb-5 h-[2px] w-14 rounded-full bg-gradient-to-r from-[#B8AF55] to-[#D8D49A]"
    ></div>

    <p
      class:list={[
        "text-base",
        "leading-relaxed",
        "text-brown/65",
      ]}
    >
      {descripcion}
    </p>
  </div>
</article>