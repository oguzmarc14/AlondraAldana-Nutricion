---
interface Props {
  botonTexto: string;
  hrefBoton: string;
  botonPrimario: boolean;
}

const { botonTexto, hrefBoton, botonPrimario } = Astro.props;
---

<div>
  <a
    href={hrefBoton}
    target={hrefBoton.startsWith("https://") ? "_blank" : undefined}
    rel={hrefBoton.startsWith("https://") ? "noopener noreferrer" : undefined}
    class:list={[
      "rounded-full",
      "inline-block",
      botonPrimario
        ? "bg-yellow border-3 text-white hover:border-yellow/80"
        : "border-3 bg-yellow/30",
      "border-yellow",
      "py-2",
      "px-6",
      "hover:scale-105",
      "duration-300",
      "font-semibold",
      "text-sm",
      "text-brown/70",
    ]}
  >
    {botonTexto}
  </a>
</div>